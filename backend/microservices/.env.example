# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=cargotrans
DB_PASSWORD=cargotrans_password
DB_NAME=cargotrans_db
DB_SSLMODE=disable
DB_MAX_CONN=25

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Auth Service Configuration
AUTH_SERVICE_HOST=0.0.0.0
AUTH_SERVICE_PORT=8001
JWT_SECRET=your_jwt_secret_key_here_change_in_production

# Shipment Service Configuration
SHIPMENT_SERVICE_HOST=0.0.0.0
SHIPMENT_SERVICE_PORT=8002

# Payment Service Configuration
PAYMENT_SERVICE_HOST=0.0.0.0
PAYMENT_SERVICE_PORT=8003

# Tracking Service Configuration
TRACKING_SERVICE_HOST=0.0.0.0
TRACKING_SERVICE_PORT=8004

# Notification Service Configuration
NOTIFICATION_SERVICE_HOST=0.0.0.0
NOTIFICATION_SERVICE_PORT=8005

# Reference Service Configuration
REFERENCE_SERVICE_HOST=0.0.0.0
REFERENCE_SERVICE_PORT=8006

# Audit Service Configuration
AUDIT_SERVICE_HOST=0.0.0.0
AUDIT_SERVICE_PORT=8007

# Report Service Configuration
REPORT_SERVICE_HOST=0.0.0.0
REPORT_SERVICE_PORT=8008

# Application Environment
ENV=development
LOG_LEVEL=debug

# CORS Settings
CORS_ALLOWED_ORIGINS=*
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization

# Rate Limiting (optional)
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_DURATION=60

# Cache Settings (optional)
CACHE_TTL=300
CACHE_MAX_SIZE=1000

# File Upload (optional)
MAX_UPLOAD_SIZE=10485760
UPLOAD_DIR=/tmp/uploads
