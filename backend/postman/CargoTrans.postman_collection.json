    {
      "name": "Shipments Lifecycle",
      "item": [
        {
          "name": "Create Shipment",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code >= 200 && pm.response.code < 300) {",
                  "  const data = pm.response.json();",
                  "  if (data.id) pm.collectionVariables.set('shipmentId', data.id);",
                  "  if (data.shipment_number) pm.collectionVariables.set('trackingCode', data.shipment_number);",
                  "  else if (data.tracking_code) pm.collectionVariables.set('trackingCode', data.tracking_code);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"client_id\": \"{{clientId}}\",\n  \"client_name\": \"Client User\",\n  \"client_email\": \"client@example.com\",\n  \"from_station\": \"Алматы-1\",\n  \"to_station\": \"Ақтөбе\",\n  \"departure_date\": \"2026-03-15T10:00:00Z\",\n  \"weight\": \"20\",\n  \"dimensions\": \"30x30x40\",\n  \"description\": \"Cargo box\",\n  \"value\": \"50000\",\n  \"cost\": 7000,\n  \"quantity_places\": 1\n}"},
            "url": "{{baseUrl}}/api/shipments"
          }
        },
        {
          "name": "Get Shipment",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/shipments/{{shipmentId}}"
          }
        },
        {
          "name": "Calculate Tariff",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/shipments/{{shipmentId}}/calculate-tariff"
